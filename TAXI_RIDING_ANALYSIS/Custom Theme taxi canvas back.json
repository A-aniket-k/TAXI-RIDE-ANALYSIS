{
  "name": "Custom Theme",
  "dataColors": [
    "#edc235",
    "#a6630f",
    "#77533e",
    "#f3bf2b",
    "#a77d44"
  ],
  "foreground": "#111827",
  "background": "#fdf9eb",
  "foregroundNeutralSecondary": "#6b7280",
  "backgroundLight": "#fbf3d7",
  "foregroundNeutralTertiary": "#6b7280",
  "backgroundNeutral": "#fefcf5",
  "tableAccent": "#edc235",
  "maximum": "#77533e",
  "center": "#a6630f",
  "minimum": "#edc235",
  "bad": "#edc235",
  "neutral": "#a6630f",
  "good": "#77533e",
  "textClasses": {
    "callout": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    },
    "title": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    },
    "header": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    },
    "label": {
      "color": "#111827",
      "fontFace": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#fefcf5"
              }
            }
          }
        ],
        "border": [
          {
            "color": {
              "solid": {
                "color": "#fefcf5"
              }
            },
            "show": true,
            "radius": 8
          }
        ],
        "visualHeader": [
          {
            "background": {
              "solid": {
                "color": "#fefcf5"
              }
            },
            "border": {
              "solid": {
                "color": "#fefcf5"
              }
            }
          }
        ]
      }
    },
    "page": {
      "*": {
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#fbf3d7"
              }
            }
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": {
              "solid": {
                "color": "#ffffff"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            }
          }
        ],
        "background": [
          {
            "color": {
              "solid": {
                "color": "#fdf9eb"
              }
            },
            "transparency": 0
          }
        ],
        "filterCard": [
          {
            "$id": "Applied",
            "backgroundColor": {
              "solid": {
                "color": "#ececec"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            },
            "transparency": 0
          },
          {
            "$id": "Available",
            "backgroundColor": {
              "solid": {
                "color": "#ffffff"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            },
            "transparency": 0
          }
        ]
      }
    }
  }
}